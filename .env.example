# Recommended: store your DeepSeek web token outside the code.
export DEEPSEEK_USER_TOKEN="paste-your-token-here"

# Alternative:
# echo "paste-your-token-here" > ~/.deepseek_token
# chmod 600 ~/.deepseek_token

# Optional: exact local token counting. Point this at the extracted tokenizer folder.
# DEEPSEEK_TOKENIZER_DIR="./deepseek_v3_tokenizer"
